{
    "name": "seekseep/wp-ai-featured-image",
    "description": "WordPress plugin to auto-generate featured images using OpenAI Images API",
    "type": "wordpress-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "seekseep"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.1",
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "phpstan/extension-installer": "^1.1",
        "phpunit/phpunit": "^10.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "WpAiFeaturedImage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpAiFeaturedImage\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "stan": "phpstan analyse --memory-limit=512M",
        "test": "phpunit"
    }
}
