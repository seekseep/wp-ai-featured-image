parameters:
    level: 8
    paths:
        - wp-ai-featured-image.php
        - src/
    excludePaths:
        - vendor/
        - tests/
    bootstrapFiles:
        - phpstan-bootstrap.php
    ignoreErrors:
        - message: '#If condition is always false#'
          path: wp-ai-featured-image.php
          reportUnmatched: false
